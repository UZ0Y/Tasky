# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv

# Environment variables (BOT TOKEN goes here – never commit this!)
.env
*.env

# SQLite databases (so your local test data stays private)
*.db
*.sqlite

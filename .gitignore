db.sqlite3

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo

# Logs and runtime data
*.log
*.pid

# OS junk
.DS_Store
Thumbs.db

# Project-specific config files (if you store tokens in JSON)
config.json
settings.json